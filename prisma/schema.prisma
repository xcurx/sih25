// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlacmentCell {
  id String @id @default(cuid())
  email String @unique
  name String
  password String
}

model Student {
  id String @id @default(cuid())
  email String @unique
  name String
  password String
  branch String?
  batch Int?
  cgpa Float?
  phone String?
  skills String[]
  resume String?
  linkedin String?
  github String?
}

model Company {
  id String @id @default(cuid())
  name String
  description String
  website String?
  industry String?
  type String?
  location String?
  employees Employer[]
  opportunities Opportunity[]
}

model Employer {
  id String @id @default(cuid())
  email String @unique
  name String
  password String
  position String?
  linkedin String?
  companyId String
  companyRel Company @relation(fields: [companyId], references: [id])
  opportunities Opportunity[]
}

model Opportunity {
  id String @id @default(cuid())
  title String
  description String
  type String
  location String
  salary String?
  postedAt DateTime @default(now())
  applicationDeadline DateTime
  requirements String[]
  eligibleDepartments String[]
  skillsRequired String[]
  additionalInfo String?
  employerId String
  employerRel Employer @relation(fields: [employerId], references: [id])
  companyId String
  companyRel Company @relation(fields: [companyId], references: [id])
}