// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PlacmentCell {
  id String @id @default(cuid())
  email String @unique
  name String
  password String
  companyReviews CompanyRequest[]
}

model Student {
  id String @id @default(cuid())
  email String @unique
  name String
  password String
  branch String?
  batch Int?
  cgpa Float?
  phone String?
  skills String[]
  resumes Resume[]
  linkedin String?
  github String?
  placed Boolean @default(false)
  applications Application[]
  mentorId String?
  mentorRel Faculty? @relation(fields: [mentorId], references: [id])
  internships Internship[]
  certificates Certificate[]
  projects Project[]
  nofiications Notification[]
  Feedbacks Feedback[]
  matchedOpportunities MatchedStudent[]
}

model Faculty {
  id String @id @default(cuid())
  email String @unique
  name String
  password String
  department String?
  phone String?
  linkedin String?
  mentees Student[]
  notifications Notification[]
}

model Company {
  id String @id @default(cuid())
  name String
  description String
  website String?
  industry String?
  type String?
  location String?
  employees Employer[]
  opportunities Opportunity[]
}

model CompanyRequest {
  id String @id @default(cuid())
  name String
  description String
  website String?
  industry String?
  type String?
  location String?
  contactName String
  contactEmail String
  contactPhone String?
  message String?
  status CompanyRequestStatus @default(pending)
  createdAt DateTime @default(now())
  reviewedAt DateTime?
  reviewNote String?
  reviewerId String?
  reviewerRel PlacmentCell? @relation(fields: [reviewerId], references: [id])
}

model Employer {
  id String @id @default(cuid())
  email String @unique
  name String
  password String
  position String?
  linkedin String?
  companyId String
  companyRel Company @relation(fields: [companyId], references: [id])
  opportunities Opportunity[]
  notifications Notification[]
}

model Opportunity {
  id String @id @default(cuid())
  title String
  description String
  type String
  location String
  status Status @default(active)
  salary String?
  postedAt DateTime @default(now())
  applicationDeadline DateTime
  cgpa Float?
  requirements String[]
  eligibleDepartments String[]
  skillsRequired String[]
  additionalInfo String?
  startDate DateTime
  endDate DateTime
  employerId String
  employerRel Employer @relation(fields: [employerId], references: [id])
  companyId String
  companyRel Company @relation(fields: [companyId], references: [id])
  applications Application[]
  internships Internship[]
  matchedStudents MatchedStudent[]
}

model Application {
  id String @id @default(cuid())
  studentId String
  studentRel Student @relation(fields: [studentId], references: [id])
  opportunityId String
  opportunityRel Opportunity @relation(fields: [opportunityId], references: [id])
  resumeId String?
  resumeRel Resume? @relation("ResumeApplications", fields: [resumeId], references: [id])
  appliedAt DateTime @default(now())
  status ApplicationStatus @default(applied)
  coverLetter String?
  mentorRemarks String?
  mentorApproved Boolean? @default(false)
  interviewRel Interview?
  intership Internship?
}

model Interview {
  id String @id @default(cuid())
  applicationId String @unique
  applicationRel Application @relation(fields: [applicationId], references: [id])
  scheduledAt DateTime
  interviewLink String
  status InterviewStatus @default(scheduled)
  interviewerDetails String?
  remarks String?
}

model Internship {
  id String @id @default(cuid())
  applicationId String @unique
  opportunityId String
  studentId String
  studentRel Student @relation(fields: [studentId], references: [id])
  opportunityRel Opportunity @relation(fields: [opportunityId], references: [id])
  applicationRel Application @relation(fields: [applicationId], references: [id])
  startDate DateTime
  endDate DateTime
  salary String?
  performanceReview String?
  certificateRel Certificate?
  employerRemarks String?
  feedbacks Feedback[]
}

model Certificate {
  id String @id @default(cuid())
  studentId String
  studentRel Student @relation(fields: [studentId], references: [id])
  title String
  issuer String
  issueDate DateTime
  certificateUrl String
  internshipId String? @unique
  internshipRel Internship? @relation(fields: [internshipId], references: [id])
}

model Project {
  id String @id @default(cuid())
  studentId String
  studentRel Student @relation(fields: [studentId], references: [id])
  title String
  description String
  startDate DateTime
  endDate DateTime?
  link String?
  technologies String[]
}

model Notification {
  id String @id @default(cuid())
  title String
  message String
  type NotificationType
  isRead Boolean @default(false)
  redirectUrl String?
  createdAt DateTime @default(now())
  
  studentId String?
  studentRel Student? @relation(fields: [studentId], references: [id])
  
  employerId String?
  employerRel Employer? @relation(fields: [employerId], references: [id])

  facultyId String?
  facultyRel Faculty? @relation(fields: [facultyId], references: [id])
}

model Feedback {
  id String @id @default(cuid())
  internshipId String
  internshipRel Internship @relation(fields: [internshipId], references: [id])
  studentId String
  studentRel Student @relation(fields: [studentId], references: [id])
  feedbackText String
  description String
  createdAt DateTime @default(now())
}

model Resume {
  id String @id @default(cuid())
  studentId String
  studentRel Student @relation(fields: [studentId], references: [id])
  resumeUrl String
  name String
  uploadedAt DateTime @default(now())
  applications Application[] @relation("ResumeApplications")

  @@unique([studentId, name])
}

model MatchedStudent {
  id String @id @default(cuid())
  studentId String
  studentRel Student @relation(fields: [studentId], references: [id])
  opportunityId String
  opportunityRel Opportunity @relation(fields: [opportunityId], references: [id])
  status MatchStatus @default(pending)
  emailSent Boolean @default(false)
  createdAt DateTime @default(now())

  @@unique([studentId, opportunityId])
}

enum Status {
  draft
  active
  closed
}

enum ApplicationStatus {
  mentor_approval_needed
  applied
  reviewed
  shortlisted
  rejected
  accepted
}

enum InterviewStatus {
  scheduled
  completed
  accepted
  rejected
  canceled
}

enum NotificationType {
  interview_scheduled
  internship_offer
  new_opportunity
  new_application
  application_rejected
  new_approval
  approval_rejected
  approval_accepted
}

enum CompanyRequestStatus {
  pending
  approved
  rejected
}

enum MatchStatus {
  pending
  accepted
  rejected
}
